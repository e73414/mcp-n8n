        }
      },
      "id": "a1000000-0000-0000-0000-000000000001",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.2,
      "position": [0, 300],
      "credentials": {
        "gmailOAuth2": {
          "id": "REPLACE_WITH_GMAIL_CRED_ID",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Classify the email as 'ingest', 'reply', or 'skip'.\nconst item = $input.first();\nconst json = item.json || {};\nconst binary = item.binary || {};\n\n// Resolve sender email from Gmail 'from' field\nconst fromRaw = json.from || '';\nconst senderEmail = (\n  fromRaw.match(/<([^>]+)>/)?.[1] || fromRaw\n).toLowerCase().trim();\n\nif (!senderEmail) {\n  return [{ json: { email_type: 'skip', reason: 'no_sender' } }];\n}\n\n// Get Message-ID and In-Reply-To from Gmail headers array\nconst headers = json.payload?.headers || [];\nconst getHeader = name => (headers.find(h => h.name.toLowerCase() === name.toLowerCase()) || {}).value || '';\nconst messageId = getHeader('Message-ID') || json.id || '';\nconst inReplyTo = getHeader('In-Reply-To') || '';\nconst subject  = json.subject || '';\nconst bodyText = json.text || json.snippet || '';\n\n// Check for a compatible file attachment\nconst compatibleExts = ['.csv', '.xlsx', '.xls', '.xlsm'];\nconst attachments = json.attachments || [];\nconst compatibleAtt = attachments.find(a => {\n  const filename = (a.fileName || a.filename || '').toLowerCase();\n  return compatibleExts.some(ext => filename.endsWith(ext));\n});\n\nif (compatibleAtt) {\n  const attFilename = compatibleAtt.fileName || compatibleAtt.filename || '';\n  // Find the binary key for this attachment\n  const binaryKey = Object.keys(binary).find(k =>\n    binary[k].fileName === attFilename\n  ) || 'attachment_0';\n  const binaryItem = binary[binaryKey];\n\n  if (!binaryItem || !binaryItem.data) {\n    return [{ json: { email_type: 'skip', reason: 'binary_missing', sender_email: senderEmail } }];\n  }\n\n  return [{ json: {\n    email_type: 'ingest',\n    sender_email: senderEmail,\n    message_id: messageId,\n    subject: subject,\n    file_name: attFilename || 'attachment',\n    file_buffer: binaryItem.data\n  }}];\n}\n\n// No attachment — check if this looks like a choice reply\nif (inReplyTo || /^\\s*[123]\\s*$/.test(bodyText)) {\n  return [{ json: {\n    email_type: 'reply',\n    sender_email: senderEmail,\n    in_reply_to: inReplyTo,\n    body_text: bodyText,\n    subject: subject\n  }}];\n}\n\nreturn [{ json: { email_type: 'skip', reason: 'no_match' } }];"
      },
      "id": "a1000000-0000-0000-0000-000000000002",
      "name": "Classify Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 300]
    },
