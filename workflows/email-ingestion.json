          "parameters": [
            { "name": "sender_email", "value": "={{ $json.sender_email }}" },
            { "name": "message_id",   "value": "={{ $json.message_id }}" },
            { "name": "subject",      "value": "={{ $json.subject }}" },
            { "name": "file_name",    "value": "={{ $json.file_name }}" },
            { "name": "file_buffer",  "value": "={{ $json.file_buffer }}" }
          ]
        },
        "options": { "timeout": 120000 }
      },
      "id": "a1000000-0000-0000-0000-000000000004",
      "name": "POST /email-ingestion/process",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [720, 80]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.action }}",
        "rules": {
          "rules": [
            { "value2": "auto_proceed" },
            { "value2": "awaiting_choice" },
            { "value2": "no_datasets" }
          ]
        },
        "fallbackOutput": 3
      },
      "id": "a1000000-0000-0000-0000-000000000005",
      "name": "Route by Ingest Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [960, 80]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst candidates = item.candidates || [];\n\nconst rows = candidates.map((c, i) =>\n  '<tr>' +\n  '<td style=\"padding:12px 16px;font-size:24px;font-weight:bold;color:#4c1d95;width:48px;text-align:center;border-right:1px solid #e5e7eb;\">' + (i + 1) + '</td>' +\n  '<td style=\"padding:12px 16px;\">' +\n  '<strong style=\"font-size:15px;color:#111;\">' + c.dataset_name + '</strong><br>' +\n  '<span style=\"color:#059669;font-size:13px;font-weight:600;\">Confidence: ' + c.confidence + '%</span><br>' +\n  '<span style=\"color:#374151;font-size:13px;\">' + c.reason + '</span>' +\n  '</td></tr>'\n).join('<tr><td colspan=\"2\" style=\"border-top:1px solid #f3f4f6;\"></td></tr>');\n\nconst html = '<!DOCTYPE html><html><body style=\"font-family:-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;color:#111;max-width:600px;margin:0 auto;padding:24px;\">' +\n  '<div style=\"border-left:4px solid #7c3aed;padding-left:16px;margin-bottom:24px;\">' +\n  '<h2 style=\"margin:0 0 4px;color:#4c1d95;\">Dataset Match Required</h2>' +\n  '<p style=\"margin:0;color:#6b7280;font-size:14px;\">File: <strong>' + (item.file_name || 'attachment') + '</strong></p></div>' +\n  '<p>We could not automatically determine which dataset this file belongs to (confidence below 90%). Please choose:</p>' +\n  '<table style=\"border-collapse:collapse;width:100%;border:1px solid #e5e7eb;overflow:hidden;margin:16px 0;\">' + rows + '</table>' +\n  '<div style=\"background:#f5f3ff;border:1px solid #ddd6fe;border-radius:8px;padding:12px 16px;\">' +\n  '<p style=\"margin:0;font-size:14px;color:#4c1d95;\"><strong>Reply to this email</strong> with just the number <strong>1</strong>, <strong>2</strong>, or <strong>3</strong> to proceed.</p></div>' +\n  '<p style=\"color:#9ca3af;font-size:12px;margin-top:24px;\">DataPilot automated ingestion</p>' +\n  '</body></html>';\n\nreturn [{ json: { ...item, choice_email_html: html } }];"
      },
